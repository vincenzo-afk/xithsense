# ── XithSense Environment Variables ──────────────────────────────────
# Copy this file to .env and fill in your actual values

# Runtime
ENV=development
DEBUG=true
LOG_LEVEL=INFO
SECRET_KEY=CHANGE_ME_TO_A_32_CHAR_MIN_RANDOM_STRING_XXXXXXXXXXX
XITHSENSE_API_KEY=xs-dev-changeme

# ── Database (PostgreSQL) ─────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/xithsense
# Supabase (optional — leave blank to use local Postgres)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_ANON_KEY=

# ── Redis ─────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Qdrant (Vector DB) ────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ── LLM (choose one) ─────────────────────────────────────────────────
LLM_PROVIDER=anthropic
# Options: anthropic | openai | google
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=AIza...
LLM_MODEL=claude-sonnet-4-6

# ── Data Paths ────────────────────────────────────────────────────────
CRICSHEET_DATA_PATH=data/raw/all_json/
MODEL_ARTIFACTS_PATH=models/artifacts/
FEATURE_STORE_PATH=data/features/

# ── Payments (Razorpay) ────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_...
RAZORPAY_KEY_SECRET=...

# ── Notifications ─────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ── Weather API ───────────────────────────────────────────────────────
WEATHER_API_KEY=

# ── CORS ──────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://app.xithsense.com
