{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "XithSense Human Intelligence Rule",
  "type": "object",
  "required": ["id", "rule_type", "condition", "impact_score", "confidence", "source"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^RULE-[0-9]{4}$",
      "description": "Unique rule ID e.g. RULE-0001"
    },
    "rule_type": {
      "type": "string",
      "enum": ["player", "venue", "matchup", "context"]
    },
    "player_key": {
      "type": ["string", "null"],
      "description": "Cricsheet registry key. NULL = all players matching condition."
    },
    "condition": {
      "type": "object",
      "description": "All key-value pairs must be true for rule to fire",
      "minProperties": 1
    },
    "impact_score": {
      "type": "integer",
      "minimum": -100,
      "maximum": 100
    },
    "confidence": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0
    },
    "description": { "type": "string" },
    "source": { "type": "string", "minLength": 5 },
    "is_active": { "type": "boolean", "default": true },
    "match_types": {
      "type": ["array", "null"],
      "items": { "type": "string" }
    },
    "valid_from": { "type": ["string", "null"], "format": "date" },
    "valid_until": { "type": ["string", "null"], "format": "date" }
  }
}
